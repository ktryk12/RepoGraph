# Model Runner
MODEL_DIR=E:/Llm/llm-server/models

# LLM / Anthropic-kompatibel server
# Sæt ANTHROPIC_BASE_URL til jeres lokale server (fx Ollama, llama.cpp, LM Studio)
# Eksempel Ollama: ANTHROPIC_BASE_URL=http://localhost:11434/v1
# Eksempel llama.cpp: ANTHROPIC_BASE_URL=http://localhost:8081/v1
# Lad blank for cloud-fallback (kræver rigtig ANTHROPIC_API_KEY)
ANTHROPIC_BASE_URL=http://host.docker.internal:8081/v1
ANTHROPIC_API_KEY=local
CLAUDE_MODEL=MA-Danish-RP-nemo-Mistral-12B.Q6_K
CREATIVE_BRIEF_MODEL=MA-Danish-RP-nemo-Mistral-12B.Q6_K

# External services (on llm-shared network)
COMFYUI_BASE_URL=http://comfyui:8188
VOICE_SERVICE_URL=http://voice-service:8130

# Ports
IMAGE_SERVICE_PORT=8110
VOICE_SERVICE_PROXY_PORT=8111

# Redis
REDIS_URL=redis://redis:6379

# Storage
SQLITE_PATH=/data/babyai.db
VISUAL_STORAGE_PATH=/data/visuals
VOICE_STORAGE_PATH=/data/audio
