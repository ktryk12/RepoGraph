# RepoGraph API
REPOGRAPH_HOST=0.0.0.0
REPOGRAPH_PORT=8001
REPOGRAPH_DB_BACKEND=cog
REPOGRAPH_DB_PATH=/data/repograph
REPOGRAPH_TENANT_ID=default
REPOGRAPH_AUTOINDEX=lazy

# Shared retrieval infrastructure
REPOGRAPH_REDIS_URL=redis://redis:6379/0
REPOGRAPH_POSTGRES_DSN=postgresql://repograph:repograph@postgres:5432/repograph
REPOGRAPH_AUTO_MIGRATE=1
REPOGRAPH_MIGRATE_ATTEMPTS=30
REPOGRAPH_MIGRATE_INTERVAL=2

# Optional Obsidian connector
OBSIDIAN_REST_API_URI=
OBSIDIAN_API_KEY=
