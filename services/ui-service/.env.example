# UI Service Configuration

# Service settings
UI_SERVICE_HOST=0.0.0.0
UI_SERVICE_PORT=8080

# WebSocket settings
WEBSOCKET_ENABLED=true
WEBSOCKET_PORT=8081

# Session management
SESSION_TIMEOUT_MINUTES=60
SESSION_SECRET_KEY=ui-service-secret-change-in-production

# Dashboard settings
DASHBOARD_REFRESH_INTERVAL=30
MAX_DASHBOARD_WIDGETS=20

# Kafka settings
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
UI_GROUP_ID=ui-service

# External service URLs
REQUEST_GATE_BASE_URL=http://localhost:8097
VIDEO_SERVICE_URL=http://localhost:8130
VOICE_SERVICE_URL=http://localhost:7080

# Database settings (dedicated ui-service database)
UI_DB_HOST=localhost
UI_DB_PORT=5432
UI_DB_NAME=ui_service_db
UI_DB_USER=ui_service_user
UI_DB_PASSWORD=ui_service_password
UI_DB_ECHO=false

# Logging
LOG_LEVEL=INFO

# Optional: UI-specific settings
# ENABLE_DEBUG_TOOLBAR=false
# STATIC_FILES_DIR=static
# TEMPLATE_DIR=templates