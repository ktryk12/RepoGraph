# Voice Service Configuration

# Service settings
VOICE_RUNTIME_HOST=0.0.0.0
VOICE_RUNTIME_PORT=7080

# STT (Speech-to-Text) settings
STT_MODEL=openai/whisper-base
STT_DEVICE=cpu

# TTS (Text-to-Speech) settings
TTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2
TTS_DEVICE=cpu
TTS_SPEAKER=Claribel Dervla

# Model assets
MODEL_ASSETS_DIR=/models

# Database settings (dedicated voice-service database)
VOICE_DB_HOST=localhost
VOICE_DB_PORT=5432
VOICE_DB_NAME=voice_service_db
VOICE_DB_USER=voice_service_user
VOICE_DB_PASSWORD=voice_service_password
VOICE_DB_ECHO=false

# Logging
LOG_LEVEL=INFO

# Optional: MCP server settings
# MCP_TRANSPORT=sse
# MCP_CAPABILITIES=stt,tts,pipeline