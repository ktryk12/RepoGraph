# Video Service Configuration

# Service settings
VIDEO_SERVICE_HOST=0.0.0.0
VIDEO_SERVICE_PORT=8130

# Video rendering
VIDEO_RENDERER=stub
VIDEO_RENDERER_API_KEY=
BABYAI_ARTIFACT_STORE=artifacts
CLAUDE_MODEL=claude-sonnet-4-6

# Kafka settings
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
VIDEO_GROUP_ID=video-service
VIDEO_TOPIC_IN=content.video.request
VIDEO_TOPIC_OUT=content.video.complete

# Database settings (dedicated video-service database)
VIDEO_DB_HOST=localhost
VIDEO_DB_PORT=5432
VIDEO_DB_NAME=video_service_db
VIDEO_DB_USER=video_service_user
VIDEO_DB_PASSWORD=video_service_password
VIDEO_DB_ECHO=false

# Logging
LOG_LEVEL=INFO

# External APIs (when not using stub mode)
# RUNWAY_API_KEY=your_runway_api_key
# SYNTHESIA_API_KEY=your_synthesia_api_key
# HEYGEN_API_KEY=your_heygen_api_key