        "source_service": {"type": "string", "const": "repo-wrapper-service"},
        "correlation_id": {"type": "string", "format": "uuid"},
        "data": {
          "type": "object",
          "properties": {
            "generation_id": {"type": "string", "format": "uuid"},
            "intake_id": {"type": "string", "format": "uuid"},
            "family_id": {"type": "string", "format": "uuid"},
            "requested_by": {"type": "string", "format": "uuid"},
            "github_owner": {"type": "string"},
            "github_repo": {"type": "string"},
            "system_adapter_draft": {"type": "object"},
            "generation_method": {"type": "string"},
            "complexity_score": {"type": "number", "minimum": 0.0, "maximum": 1.0},
            "confidence_score": {"type": "number", "minimum": 0.0, "maximum": 1.0},
            "template_used": {"type": "string"},
            "draft_ready_at": {"type": "string", "format": "date-time"}
          },
          "required": ["generation_id", "intake_id", "family_id", "requested_by", "github_owner", "github_repo", "system_adapter_draft"]
        }
      },
      "required": ["event_id", "event_type", "event_version", "timestamp", "source_service", "data"]
    },

    "adapter.approved.v1": {
      "type": "object",
      "properties": {
