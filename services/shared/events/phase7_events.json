  },

  "event_routing": {
    "topics": {
      "repo-intake": ["repo.intake.created.v1", "repo.intake.validated.v1", "repo.artifact.created.v1"],
      "security-scanning": ["security.scan.requested.v1", "security.scan.completed.v1", "security.scan.failed.v1", "security.scan.summary.ready.v1"],
      "adapter-generation": ["adapter.draft.requested.v1", "adapter.draft.ready.v1", "adapter.approved.v1", "adapter.rejected.v1", "adapter.registered.v1"]
    },
    "producers": {
      "repo-intake-service": ["repo.intake.created.v1", "repo.intake.validated.v1", "repo.artifact.created.v1", "security.scan.requested.v1", "security.scan.summary.ready.v1", "adapter.draft.requested.v1"],
      "malware-scanner": ["security.scan.completed.v1", "security.scan.failed.v1"],
      "license-checker": ["security.scan.completed.v1", "security.scan.failed.v1"],
      "cve-scanner": ["security.scan.completed.v1", "security.scan.failed.v1"],
      "content-policy-checker": ["security.scan.completed.v1", "security.scan.failed.v1"],
      "prompt-injection-detector": ["security.scan.completed.v1", "security.scan.failed.v1"],
      "repo-wrapper-service": ["adapter.draft.ready.v1", "adapter.approved.v1", "adapter.rejected.v1", "adapter.registered.v1"]
    },
    "consumers": {
      "repo-intake-service": ["security.scan.completed.v1", "security.scan.failed.v1"],
      "repo-wrapper-service": ["adapter.draft.requested.v1", "security.scan.summary.ready.v1"],
      "ui-gateway": ["repo.intake.created.v1", "repo.artifact.created.v1", "security.scan.summary.ready.v1", "adapter.draft.ready.v1", "adapter.approved.v1", "adapter.rejected.v1", "adapter.registered.v1"],
      "malware-scanner": ["security.scan.requested.v1"],
      "license-checker": ["security.scan.requested.v1"],
      "cve-scanner": ["security.scan.requested.v1"],
      "content-policy-checker": ["security.scan.requested.v1"],
      "prompt-injection-detector": ["security.scan.requested.v1"]
    }
  },

  "security_thresholds": {
    "default_config": {
      "malware-scanner": {
        "advisory_mode": true,
        "critical_threshold": 1,
        "action_on_critical": "block"
      },
      "cve-scanner": {
        "advisory_mode": true,
        "critical_threshold": 3,
        "action_on_critical": "approval_required"
      },
      "license-checker": {
        "advisory_mode": true,
        "critical_threshold": 1,
        "action_on_critical": "approval_required"
      },
      "content-policy-checker": {
        "advisory_mode": true,
        "critical_threshold": 1,
        "action_on_critical": "approval_required"
      },
      "prompt-injection-detector": {
        "advisory_mode": true,
        "critical_threshold": 2,
        "action_on_critical": "advisory"
      }
    }
  }
}