{
  "schemas": {
    "repo.intake.created.v1": {
      "type": "object",
      "properties": {
        "event_id": {"type": "string", "format": "uuid"},
        "event_type": {"type": "string", "const": "repo.intake.created.v1"},
        "event_version": {"type": "string", "const": "1.0"},
        "timestamp": {"type": "string", "format": "date-time"},
        "source_service": {"type": "string", "const": "repo-intake-service"},
        "correlation_id": {"type": "string", "format": "uuid"},
        "data": {
          "type": "object",
          "properties": {
            "intake_id": {"type": "string", "format": "uuid"},
            "family_id": {"type": "string", "format": "uuid"},
            "requested_by": {"type": "string", "format": "uuid"},
            "github_url": {"type": "string", "format": "uri"},
            "github_owner": {"type": "string"},
            "github_repo": {"type": "string"},
            "github_branch": {"type": "string", "default": "main"},
            "priority": {"type": "integer", "minimum": 1, "maximum": 10},
            "scan_config": {"type": "object"},
            "created_at": {"type": "string", "format": "date-time"}
          },
          "required": ["intake_id", "family_id", "requested_by", "github_url", "github_owner", "github_repo"]
        }
      },
      "required": ["event_id", "event_type", "event_version", "timestamp", "source_service", "data"]
    },

    "repo.intake.validated.v1": {
      "type": "object",
      "properties": {
        "event_id": {"type": "string", "format": "uuid"},
        "event_type": {"type": "string", "const": "repo.intake.validated.v1"},
        "event_version": {"type": "string", "const": "1.0"},
        "timestamp": {"type": "string", "format": "date-time"},
        "source_service": {"type": "string", "const": "repo-intake-service"},
        "correlation_id": {"type": "string", "format": "uuid"},
        "data": {
          "type": "object",
          "properties": {
            "intake_id": {"type": "string", "format": "uuid"},
            "family_id": {"type": "string", "format": "uuid"},
            "validation_result": {"type": "string", "enum": ["valid", "invalid"]},
            "validation_details": {"type": "object"},
            "github_url": {"type": "string", "format": "uri"},
            "normalized_url": {"type": "string", "format": "uri"},
            "error_message": {"type": "string"}
          },
          "required": ["intake_id", "family_id", "validation_result", "github_url"]
        }
      },
      "required": ["event_id", "event_type", "event_version", "timestamp", "source_service", "data"]
    },

    "repo.artifact.created.v1": {
      "type": "object",
      "properties": {
        "event_id": {"type": "string", "format": "uuid"},
        "event_type": {"type": "string", "const": "repo.artifact.created.v1"},
        "event_version": {"type": "string", "const": "1.0"},
        "timestamp": {"type": "string", "format": "date-time"},
        "source_service": {"type": "string", "const": "repo-intake-service"},
        "correlation_id": {"type": "string", "format": "uuid"},
        "data": {
          "type": "object",
          "properties": {
            "intake_id": {"type": "string", "format": "uuid"},
            "artifact_id": {"type": "string", "format": "uuid"},
            "family_id": {"type": "string", "format": "uuid"},
            "artifact_uri": {"type": "string", "format": "uri"},
            "source_url": {"type": "string", "format": "uri"},
            "commit_sha": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
            "branch": {"type": "string"},
            "repo_size_bytes": {"type": "integer", "minimum": 0},
            "file_count": {"type": "integer", "minimum": 0},
            "languages": {"type": "array", "items": {"type": "string"}},
            "frameworks": {"type": "array", "items": {"type": "string"}},
            "package_managers": {"type": "array", "items": {"type": "string"}},
            "has_dependencies": {"type": "boolean"},
            "created_at": {"type": "string", "format": "date-time"}
          },
          "required": ["intake_id", "artifact_id", "family_id", "artifact_uri", "source_url", "commit_sha", "branch"]
        }
      },
      "required": ["event_id", "event_type", "event_version", "timestamp", "source_service", "data"]
    },

    "security.scan.requested.v1": {
      "type": "object",
      "properties": {
        "event_id": {"type": "string", "format": "uuid"},
        "event_type": {"type": "string", "const": "security.scan.requested.v1"},
        "event_version": {"type": "string", "const": "1.0"},
        "timestamp": {"type": "string", "format": "date-time"},
        "source_service": {"type": "string", "const": "repo-intake-service"},
        "correlation_id": {"type": "string", "format": "uuid"},
        "data": {
          "type": "object",
          "properties": {
            "scan_job_id": {"type": "string", "format": "uuid"},
            "intake_id": {"type": "string", "format": "uuid"},
            "artifact_id": {"type": "string", "format": "uuid"},
            "family_id": {"type": "string", "format": "uuid"},
            "scanner_type": {
              "type": "string",
              "enum": ["malware-scanner", "license-checker", "cve-scanner", "content-policy-checker", "prompt-injection-detector"]
            },
            "priority": {"type": "integer", "minimum": 1, "maximum": 10},
            "artifact_uri": {"type": "string", "format": "uri"},
            "timeout_seconds": {"type": "integer", "minimum": 30, "maximum": 3600},
            "scanner_config": {
              "type": "object",
              "properties": {
                "advisory_mode": {"type": "boolean"},
                "critical_threshold": {"type": "integer", "minimum": 1},
                "action_on_critical": {"type": "string", "enum": ["advisory", "approval_required", "block"]}
              },
              "required": ["advisory_mode"]
            },
            "created_at": {"type": "string", "format": "date-time"}
          },
          "required": ["scan_job_id", "intake_id", "artifact_id", "family_id", "scanner_type", "artifact_uri", "scanner_config"]
        }
      },
      "required": ["event_id", "event_type", "event_version", "timestamp", "source_service", "data"]
    },

    "security.scan.completed.v1": {
      "type": "object",
      "properties": {
        "event_id": {"type": "string", "format": "uuid"},
        "event_type": {"type": "string", "const": "security.scan.completed.v1"},
        "event_version": {"type": "string", "const": "1.0"},
        "timestamp": {"type": "string", "format": "date-time"},
        "source_service": {"type": "string", "pattern": "^(malware|license|cve|content-policy|prompt-injection)-.+$"},
        "correlation_id": {"type": "string", "format": "uuid"},
        "data": {
          "type": "object",
          "properties": {
            "scan_job_id": {"type": "string", "format": "uuid"},
            "intake_id": {"type": "string", "format": "uuid"},
            "artifact_id": {"type": "string", "format": "uuid"},
            "scanner_type": {
              "type": "string",
              "enum": ["malware-scanner", "license-checker", "cve-scanner", "content-policy-checker", "prompt-injection-detector"]
            },
            "status": {"type": "string", "enum": ["clean", "findings", "error"]},
            "severity": {"type": "string", "enum": ["info", "low", "medium", "high", "critical"]},
            "findings_count": {"type": "integer", "minimum": 0},
            "findings": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {"type": "string"},
                  "severity": {"type": "string", "enum": ["info", "low", "medium", "high", "critical"]},
                  "category": {"type": "string"},
                  "file": {"type": "string"},
                  "line": {"type": "integer", "minimum": 1},
                  "column": {"type": "integer", "minimum": 1},
                  "message": {"type": "string"},
                  "description": {"type": "string"},
                  "recommendation": {"type": "string"},
                  "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
                  "metadata": {"type": "object"}
                },
                "required": ["id", "severity", "message"]
              }
            },
            "scan_metadata": {
              "type": "object",
              "properties": {
                "scan_duration_ms": {"type": "integer", "minimum": 0},
                "files_scanned": {"type": "integer", "minimum": 0},
                "bytes_scanned": {"type": "integer", "minimum": 0},
                "scanner_version": {"type": "string"},
                "ruleset_version": {"type": "string"}
              }
            },
            "confidence_score": {"type": "number", "minimum": 0.0, "maximum": 1.0},
            "false_positive_risk": {"type": "string", "enum": ["low", "medium", "high"]},
            "completed_at": {"type": "string", "format": "date-time"}
          },
          "required": ["scan_job_id", "intake_id", "artifact_id", "scanner_type", "status", "severity", "findings_count", "findings"]
        }
      },
      "required": ["event_id", "event_type", "event_version", "timestamp", "source_service", "data"]
    },

    "security.scan.failed.v1": {
      "type": "object",
      "properties": {
        "event_id": {"type": "string", "format": "uuid"},
        "event_type": {"type": "string", "const": "security.scan.failed.v1"},
        "event_version": {"type": "string", "const": "1.0"},
        "timestamp": {"type": "string", "format": "date-time"},
        "source_service": {"type": "string", "pattern": "^(malware|license|cve|content-policy|prompt-injection)-.+$"},
        "correlation_id": {"type": "string", "format": "uuid"},
        "data": {
          "type": "object",
          "properties": {
            "scan_job_id": {"type": "string", "format": "uuid"},
            "intake_id": {"type": "string", "format": "uuid"},
            "artifact_id": {"type": "string", "format": "uuid"},
            "scanner_type": {
              "type": "string",
              "enum": ["malware-scanner", "license-checker", "cve-scanner", "content-policy-checker", "prompt-injection-detector"]
            },
            "error_type": {"type": "string", "enum": ["timeout", "artifact_not_found", "scanner_error", "validation_error", "resource_limit"]},
            "error_message": {"type": "string"},
            "retry_count": {"type": "integer", "minimum": 0},
            "max_retries": {"type": "integer", "minimum": 0},
            "will_retry": {"type": "boolean"},
            "failed_at": {"type": "string", "format": "date-time"}
          },
          "required": ["scan_job_id", "intake_id", "artifact_id", "scanner_type", "error_type", "error_message"]
        }
      },
      "required": ["event_id", "event_type", "event_version", "timestamp", "source_service", "data"]
    },

    "security.scan.summary.ready.v1": {
      "type": "object",
      "properties": {
        "event_id": {"type": "string", "format": "uuid"},
        "event_type": {"type": "string", "const": "security.scan.summary.ready.v1"},
        "event_version": {"type": "string", "const": "1.0"},
        "timestamp": {"type": "string", "format": "date-time"},
        "source_service": {"type": "string", "const": "repo-intake-service"},
        "correlation_id": {"type": "string", "format": "uuid"},
        "data": {
          "type": "object",
          "properties": {
            "intake_id": {"type": "string", "format": "uuid"},
            "artifact_id": {"type": "string", "format": "uuid"},
            "family_id": {"type": "string", "format": "uuid"},
            "overall_status": {"type": "string", "enum": ["completed", "partial", "failed"]},
            "overall_severity": {"type": "string", "enum": ["info", "low", "medium", "high", "critical"]},
            "action_required": {"type": "string", "enum": ["none", "advisory", "approval_required", "blocked"]},
            "scanners_completed": {"type": "integer", "minimum": 0},
            "scanners_failed": {"type": "integer", "minimum": 0},
            "scanners_total": {"type": "integer", "minimum": 1},
            "total_findings": {"type": "integer", "minimum": 0},
            "findings_by_severity": {
              "type": "object",
              "properties": {
                "critical": {"type": "integer", "minimum": 0},
                "high": {"type": "integer", "minimum": 0},
                "medium": {"type": "integer", "minimum": 0},
                "low": {"type": "integer", "minimum": 0},
                "info": {"type": "integer", "minimum": 0}
              }
            },
            "scanner_summaries": {
              "type": "object",
              "patternProperties": {
                "^(malware-scanner|license-checker|cve-scanner|content-policy-checker|prompt-injection-detector)$": {
                  "type": "object",
                  "properties": {
                    "status": {"type": "string", "enum": ["completed", "failed"]},
                    "findings_count": {"type": "integer", "minimum": 0},
                    "max_severity": {"type": "string", "enum": ["info", "low", "medium", "high", "critical"]},
                    "duration_ms": {"type": "integer", "minimum": 0}
                  }
                }
              }
            },
            "blocking_findings": {"type": "array", "items": {"type": "object"}},
            "recommendations": {"type": "array", "items": {"type": "string"}},
            "scan_completed_at": {"type": "string", "format": "date-time"}
          },
          "required": ["intake_id", "artifact_id", "family_id", "overall_status", "overall_severity", "action_required", "scanners_completed", "scanners_total", "total_findings"]
        }
      },
      "required": ["event_id", "event_type", "event_version", "timestamp", "source_service", "data"]
    },

    "adapter.draft.requested.v1": {
      "type": "object",
      "properties": {
