            "github_owner": {"type": "string"},
            "github_repo": {"type": "string"},
            "commit_sha": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
            "artifact_uri": {"type": "string", "format": "uri"},
            "security_summary": {"type": "object"},
            "repo_analysis": {"type": "object"},
            "priority": {"type": "integer", "minimum": 1, "maximum": 10},
            "requested_at": {"type": "string", "format": "date-time"}
          },
          "required": ["generation_id", "intake_id", "artifact_id", "family_id", "requested_by", "github_url", "github_owner", "github_repo", "commit_sha", "artifact_uri"]
        }
      },
      "required": ["event_id", "event_type", "event_version", "timestamp", "source_service", "data"]
    },

    "adapter.draft.ready.v1": {
      "type": "object",
      "properties": {
        "event_id": {"type": "string", "format": "uuid"},
        "event_type": {"type": "string", "const": "adapter.draft.ready.v1"},
