{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://babyai.app/schemas/skill-manifest/v1",
  "title": "SKILL.md frontmatter schema",
  "description": "JSON Schema for babyAI SKILL.md frontmatter. Valideres ved load og CI.",
  "type": "object",
  "required": ["skill_id", "name", "version", "description", "domains", "expert_routing"],
  "additionalProperties": true,
  "properties": {
    "skill_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,63}$",
      "description": "Unikt kebab-case identifier. Bruges som Kafka event-prefix."
    },
    "name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 80
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version (major.minor.patch)"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500,
      "description": "Hvornår skal denne skill bruges? Inkluder trigger-ord."
    },
    "domains": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1,
      "description": "Primære domæner, fx [code, security, content]"
    },
    "dimensions": {
      "type": "array",
      "items": {"type": "string"},
      "default": []
    },
    "expert_routing": {
      "type": "object",
      "required": ["model"],
      "properties": {
        "model": {
          "type": "string",
          "enum": ["code-codestral", "general", "danish", "vision"],
          "description": "Lokal model der bruges — aldrig claude-sonnet eller Anthropic API"
        },
        "danish_version": {
          "type": "boolean",
          "default": false
        },
        "temperature": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 2.0,
          "default": 0.3
        },
        "max_tokens": {
          "type": "integer",
          "minimum": 100,
          "maximum": 4096,
          "default": 1500
        }
      }
    },
    "babyai_conventions": {
      "type": "object",
      "properties": {
        "respect": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Konventioner der respekteres"
        },
        "flag": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Mønstre der skal markeres"
        }
      }
    },
    "telemetry": {
      "type": "object",
      "properties": {
        "emit_events": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Kafka-events der emitteres ved start og completion"
        }
      }
    },
    "triggers": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Trigger-ord/fraser der aktiverer skill'en"
    }
  }
}
